{
  "name": "angular-schematics-extension",
  "displayName": "Angular Schematics",
  "description": "在Angular项目中快速生成原理图",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:angular-schematics.generate",
    "onCommand:extension.sortPythonImports",
    "onCommand:extension.sortPythonImportsFromSnippet",
    "onCommand:extension.triggerCodeContinuation",
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "angular-schematics.generate",
        "title": "Angular 原理图",
        "category": "Angular"
      },
      {
        "command": "case.showModal",
        "title": "Case: 打开对话框",
        "category": "Case"
      },
      {
        "command": "case.showWizard",
        "title": "Case: 向导(原生)",
        "category": "Case"
      },
      {
        "command": "extension.searchWithBuiltinRg",
        "title": "文本搜索"
      },
      {
        "command": "extension.findFiles",
        "title": "查找文件",
        "category": "文件操作"
      },
      {
        "command": "case.expandView",
        "title": "Case: 展开视图",
        "category": "Case"
      },
      {
        "command": "extension.openEditableDiff",
        "title": "打开可编辑 Diff",
        "category": "文件对比"
      },
      {
        "command": "extension.saveEditableDiffRight",
        "title": "保存 Diff 右侧内容",
        "category": "文件对比"
      },
      {
        "command": "extension.sortPythonImports",
        "title": "排序 Python 导入（系统库 → 三方库 → 本地）",
        "category": "Python"
      },
      {
        "command": "extension.sortPythonImportsFromSnippet",
        "title": "排序 Python 导入（对选中片段：输入片段 → 输出排序后片段）",
        "category": "Python"
      },
      {
        "command": "extension.triggerCodeContinuation",
        "title": "代码续写（内联补全）",
        "category": "AI"
      }
    ],
    "keybindings": [
      {
        "command": "extension.triggerCodeContinuation",
        "key": "alt+v",
        "when": "editorTextFocus && !editorReadonly"
      }
    ],
    "configuration": {
      "title": "代码续写",
      "properties": {
        "codeContinuation.endpoint": {
          "type": "string",
          "default": "",
          "description": "代码续写服务的 HTTP 接口地址。留空则使用内置的本地启发式示例。请求 body 为 { prefix, suffix, languageId }，返回 { completion: string } 或纯字符串。"
        },
        "codeContinuation.apiKey": {
          "type": "string",
          "default": "",
          "description": "代码续写服务的 API Key（可选），会作为 Authorization: Bearer <key> 请求头发送。"
        },
        "codeContinuation.timeoutMs": {
          "type": "number",
          "default": 8000,
          "description": "代码续写请求超时时间（毫秒）。"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "aiAssistantView",
          "title": "AI 助手",
          "icon": "$(symbol-misc)"
        }
      ]
    },
    "views": {
      "aiAssistantView": [
        {
          "id": "aiAssistant",
          "name": "AI 助手",
          "type": "webview",
          "when": "true"
        }
      ],
      "explorer": [
        {
          "id": "testCase",
          "name": "Case",
          "type": "webview",
          "when": "true"
        }
      ]
    },
    "menus": {
      "explorer/context": [
        {
          "command": "angular-schematics.generate",
          "group": "navigation",
          "when": "workspaceFolderCount > 0"
        }
      ],
      "commandPalette": [
        {
          "command": "angular-schematics.generate",
          "when": "workspaceFolderCount > 0"
        },
        {
          "command": "extension.sortPythonImports",
          "when": "editorLangId == python"
        },
        {
          "command": "extension.sortPythonImportsFromSnippet",
          "when": "editorLangId == python"
        }
      ],
      "editor/context": [
        {
          "command": "angular-schematics.generate",
          "group": "navigation",
          "when": "workspaceFolderCount > 0"
        },
        {
          "command": "extension.sortPythonImports",
          "group": "1_modification",
          "when": "editorLangId == python"
        },
        {
          "command": "extension.sortPythonImportsFromSnippet",
          "group": "1_modification",
          "when": "editorLangId == python"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "compile": "tsc -p ./",
    "build": "node esbuild.config.js",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/glob": "^8.0.0",
    "@types/mocha": "^10.0.0",
    "@types/node": "16.x",
    "@types/vscode": "^1.74.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vscode/test-electron": "^2.3.8",
    "esbuild": "^0.19.0",
    "eslint": "^8.0.0",
    "glob": "^10.0.0",
    "mocha": "^10.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@angular-devkit/schematics": "^17.0.0",
    "@angular/cli": "^17.0.0",
    "@vscode/ripgrep": "^1.17.0",
    "axios": "^1.13.2",
    "tree-sitter": "^0.20.4",
    "tree-sitter-python": "^0.20.4"
  }
}
